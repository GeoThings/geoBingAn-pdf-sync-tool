<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.geothings.geobingan.healthcheck</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>sleep 30 &amp;&amp; cd /Users/geothingsmacbookair/Developer/geoBingAn-pdf-sync-tool &amp;&amp; echo "[$(date '+%F %T')] launchd fired, post-sleep, starting python..." >> logs/health_check.log &amp;&amp; ./venv/bin/python3 health_check.py --notify >> logs/health_check.log 2>&amp;1</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardErrorPath</key>
    <string>/Users/geothingsmacbookair/Developer/geoBingAn-pdf-sync-tool/logs/launchd_healthcheck_err.log</string>
</dict>
</plist>
