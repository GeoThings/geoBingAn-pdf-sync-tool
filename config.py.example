"""
配置檔案範例 - 請複製為 config.py 並填入實際值

⚠️ 請勿直接使用此檔案！
請執行：cp config.py.example config.py
然後編輯 config.py 填入您的認證資訊
"""

# JWT Token（從後端取得，有效期約 1 小時）
JWT_TOKEN = 'your-jwt-token-here'

# Refresh Token（用於自動刷新 access token，有效期 7 天）
REFRESH_TOKEN = 'your-refresh-token-here'

# 用戶資訊
USER_EMAIL = 'your-email@example.com'
USER_ID = 'your-user-id-here'

# 群組資訊
GROUP_ID = 'your-group-id-here'
GROUP_NAME = 'your-group-name-here'

# API 設定（正式環境）
GEOBINGAN_BASE_URL = 'https://riskmap.today'
GEOBINGAN_API_URL = 'https://riskmap.today/api/reports/construction-reports/upload/'
GEOBINGAN_REFRESH_URL = 'https://riskmap.today/api/auth/auth/refresh_token/'
