# geoBingAn PDF Sync Tool 環境變數設定
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env

# ============================================
# Google Drive 設定
# ============================================
GOOGLE_CREDENTIALS=./credentials.json
SHARED_DRIVE_ID=your-shared-drive-id

# ============================================
# geoBingAn API 認證
# ============================================
JWT_TOKEN=your-jwt-token
REFRESH_TOKEN=your-refresh-token
USER_EMAIL=your-email@example.com
USER_ID=your-user-id
GROUP_ID=your-group-id
GROUP_NAME=your-group-name

# ============================================
# API 端點
# ============================================
GEOBINGAN_BASE_URL=https://riskmap.today
GEOBINGAN_API_URL=https://riskmap.today/api/reports/construction-reports/upload/
GEOBINGAN_REFRESH_URL=https://riskmap.today/api/auth/auth/refresh_token/

# ============================================
# 通知設定 (可選)
# ============================================
# LINE Notify Token (從 https://notify-bot.line.me/ 取得)
LINE_NOTIFY_TOKEN=

# 啟用 macOS 通知 (true/false)
ENABLE_MACOS_NOTIFY=true

# ============================================
# 同步設定
# ============================================
# 單次最多上傳數量 (程式碼內 MAX_UPLOADS，預設 100)
# 上傳間隔 0.5 秒（程式碼內 DELAY_BETWEEN_UPLOADS，不可透過環境變數調整）
